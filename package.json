{
  "name": "dropflow",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "turbo test",
    "db:generate": "pnpm --filter @dropflow/db prisma generate",
    "db:migrate": "pnpm --filter @dropflow/db prisma migrate dev",
    "db:studio": "pnpm --filter @dropflow/db prisma studio",
    "db:seed": "pnpm --filter @dropflow/db seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
